# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Local raw memory (per project memory architecture)
# 仅 ignore runtime agent 会话记录; .louke/wiki/ 和 .louke/project/
# (wiki + 历史 spec) 仍 tracked, 因为这是 louke 框架自己的开发历史,
# 对应 README 里 "Status" / "Wiki" 章节内容。
.louke/raw/

# Librarian temp files (FR-0100 / FR-0140.2)
.louke/wiki

# Test/cache files
.coverage
.pytest_cache/
.mypy_cache/

# Tool-installed (auto-generated)
louke.egg-info/
.github/agents/*
.opencode/

# canonical: louke/agents/ and louke/templates/ (包内数据, 单一来源)
# 禁止在仓库根目录创建同名目录 (避免双份漂移)
/agents/
/templates/
# Makefile is intentionally tracked (provides `make test` for CI).

# Session artifacts (per-agent / per-IDE state)
.kilo/
.sisyphus/
.trae/

# Web server runtime state (local auth users, serve activity log)
.louke/web-users.json
.louke/project/.serve-activity.jsonl

# Local model alias overrides (per-machine; not framework config)
.louke/models.json

# Stray worktrees created inside the repo (should live outside, but ignore if present)
/v0.7.3/
/v0.7-skill-fix/
.louke/wiki/**
.louke/agents/
.louke/templates/
.opencode/agents/
.louke/project/stage-results
.tmp_bundle/
