#!/usr/bin/env bash
# specforge — TDD-driven multi-agent development framework CLI
#
# 这个脚本是 specforge 工具的"统一入口",被:
#   1. install.sh 装到 ~/.local/bin/specforge
#   2. 每个项目的 agent prompt 调用 (通过 $PATH)
#   3. 用户在终端直接调用
#
# 设计原则:
#   - 永远不假设调用方知道工具的内部位置
#   - 所有 Python 调用经由此脚本(未来加 venv 时改一处即可)
#   - 子命令和 help 自描述(无需看 README 也能上手)

set -euo pipefail

# SPECFORGE_HOME: framework 安装目录 (含 agents/templates/tools/VERSION)
# 默认 ~/.specforge; 开发者本地可直接 SPECFORGE_HOME=. ./bin/specforge ...
SPECFORGE_HOME="${SPECFORGE_HOME:-$HOME/.specforge}"

VERSION="$(cat "$SPECFORGE_HOME/VERSION" 2>/dev/null || echo "dev")"

# ---------- helpers ----------

die() { echo "specforge: $*" >&2; exit 1; }
note() { echo "specforge: $*" >&2; }

# resolve_python: 选解释器,优先 framework 自带 venv(未来),否则系统 python3
resolve_python() {
    if [ -x "$SPECFORGE_HOME/.venv/bin/python" ]; then
        echo "$SPECFORGE_HOME/.venv/bin/python"
    elif command -v python3 >/dev/null 2>&1; then
        command -v python3
    else
        die "python3 not found on PATH"
    fi
}

# resolve_spec_path: 给定相对/绝对路径,如果原路径不存在,
# 尝试在 git root 重新解析。这样 agent 在任意 cwd 跑 quote-check 都能找到 spec。
# 用法: resolve_spec_path <arg>  → echo 解析后的绝对路径
resolve_spec_path() {
    local P="$1"
    [ -z "$P" ] && { echo ""; return; }
    # 已经是绝对路径 / 原路径存在 → 原样返回
    if [[ "$P" = /* ]] || [ -f "$P" ]; then
        echo "$P"
        return
    fi
    # 尝试 git root 下的相对路径
    if command -v git >/dev/null 2>&1; then
        local ROOT
        ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
        if [ -n "$ROOT" ] && [ -f "$ROOT/$P" ]; then
            echo "$ROOT/$P"
            return
        fi
    fi
    # 找不到就原样返回,让 Python 脚本自己报错
    echo "$P"
}

# ---------- subcommands ----------

cmd_version() {
    echo "specforge $VERSION"
    echo "  install path: $SPECFORGE_HOME"
}

cmd_help() {
    cat <<EOF
specforge $VERSION — TDD-driven multi-agent development framework

提示: 大多数命令由 agent 在 AI 工具上下文内自动调用 (init 除外),
人跑这些命令主要是为了 debug。详细分类见 README §8.9。

Usage:
  specforge <command> [args]

Commands (User-driven — 人跑):
  init <name>             新建 <name>/ 子项目(拷贝 agents/templates 到 .specforge/)
  init <path>             接入既存项目 (adopt 模式),非破坏性合并
                          Flags: --dry-run --backup --force --no-gitignore
                                 --with-issue-template --json
  upgrade                 git pull --ff-only 到 \$SPECFORGE_HOME (拒绝非 main 分支)
  version                 打印版本 + install 路径
  help                    显示本帮助

Commands (Agent-driven — AI 工具内调用,人跑只为 debug):
  checkup <owner/repo>    身份一致性体检 L1-L5 (Maestro 启动时跑)
  doctor                  checkup 的别名
  foundation <owner/repo> 项目奠基检查 F1-F9 (Scout 完成后验证)
                          Flags: --version V --spec-id ID [--project-id N]
                                 [--upstream BRANCH] [--skip F3,F4] [--offline]
  invite-owner <o/r>      把 repo owner 设为对应 Project 的 collaborator (READER)
                          Flags: --version V
  verify-issue --spec ID  Feature issue form schema 验证 L1-L8 (Lex 阶段三跑)
  quote-check [args]     解析 spec.md quote block + --check-ready 验证
                          (Sage/Lex 阶段六用,所有参数透传给 quote_parser.py)
                          spec path 缺失时自动在 git root 下解析
  verify-acceptance     验证 Sage 生成的 acceptance.md (Lex 阶段一)
                          Flags: --spec ID | --offline --spec-file F --acceptance-file F
                          (L1-L5: 文件存在/FR-NFR 对应/AC 编号/AC 内容/反向覆盖)

环境变量:
  SPECFORGE_HOME          framework 安装目录 (默认 ~/.specforge)
  GH_REPO                 specforge 的 GitHub repo (默认 zillionare/specforge)

更多信息: https://github.com/\${GH_REPO:-zillionare/specforge}
EOF
}

cmd_init() {
    local PROJECT_NAME="${1:-}"
    if [ -z "$PROJECT_NAME" ]; then
        die "Usage: specforge init <project-name>"
    fi

    # Adopt mode: path with /, . prefix, or ~ prefix and target exists.
    # Bare name (no separators and not .) → legacy create-new mode.
    if is_existing_path "$PROJECT_NAME"; then
        shift  # drop the path positional
        cmd_init_adopt "$PROJECT_NAME" "$@"
        return
    fi

    cmd_init_new "$PROJECT_NAME"
}

# is_existing_path: detect whether the argument represents a path
# to an existing directory (adopt mode) versus a new bare name (legacy).
# Rules (per FR-008, spec 003-init-adopt-mode):
#   - "." alone                              → adopt
#   - starts with "./" "/" "~/" or "../"     → adopt if target exists
#   - bare name (no separators)              → never adopt
is_existing_path() {
    local arg="$1"
    case "$arg" in
        "."|"./"|"../") return 0 ;;
        ./*|../*|/*|~*) [ -d "$arg" ] && return 0 || return 1 ;;
        *) return 1 ;;
    esac
}

cmd_init_new() {
    local PROJECT_NAME="$1"
    if [ -d "$PROJECT_NAME" ]; then
        die "Directory '$PROJECT_NAME' already exists"
    fi

    [ -d "$SPECFORGE_HOME/agents" ] || die "agents/ not found in $SPECFORGE_HOME — is specforge installed?"
    [ -d "$SPECFORGE_HOME/templates" ] || die "templates/ not found in $SPECFORGE_HOME"

    # 目录布局:
    #   .specforge/agents/      框架资产副本 (本地, 不入库)
    #   .specforge/templates/   框架资产副本 (本地, 不入库)
    #   .specforge/project/     项目产出物 (project-info.md, specs/) — install/uninstall 不触碰
    #
    # init 只创建 agents/ templates/ 与 project/ 占位; project/ 下的文件由 Scout/Sage 等后续 agent 创建.
    mkdir -p "$PROJECT_NAME"/{.specforge/agents,.specforge/templates,.specforge/project,wiki/pages,wiki/decisions,raw/sources}
    cp "$SPECFORGE_HOME"/agents/*.md "$PROJECT_NAME/.specforge/agents/" 2>/dev/null || true
    cp "$SPECFORGE_HOME"/templates/*.md "$PROJECT_NAME/.specforge/templates/" 2>/dev/null || true
    cp "$SPECFORGE_HOME"/agents/ROSTER.md "$PROJECT_NAME/.specforge/agents/" 2>/dev/null || true

    # FR-029: .github/agents/*.agent.md 软链 (VS Code custom agent 发现)
    # 只有检测到 .vscode/ 目录 (说明用户使用 VS Code) 才创建, 不强制性.
    if [ -d "$PROJECT_NAME/.vscode" ]; then
        mkdir -p "$PROJECT_NAME/.github/agents"
        local AGENT_DIR="$PROJECT_NAME/.specforge/agents"
        for f in "$AGENT_DIR"/*.md; do
            [ -f "$f" ] || continue
            local agent_base
            agent_base=$(basename "$f" .md)
            # 相对路径: .github/agents/X.agent.md → ../../.specforge/agents/X.md
            ln -snf "../../.specforge/agents/${agent_base}.md" \
                "$PROJECT_NAME/.github/agents/${agent_base}.agent.md"
        done
        # .gitignore 追加 .github/agents/ (本地配置不入库)
        local GITIGNORE="$PROJECT_NAME/.gitignore"
        if [ ! -f "$GITIGNORE" ]; then
            printf '.github/agents/\n' > "$GITIGNORE"
        elif ! grep -qxF '.github/agents/' "$GITIGNORE" 2>/dev/null; then
            printf '\n.github/agents/\n' >> "$GITIGNORE"
        fi
    fi

    # 把 agents/ 与 templates/ 副本从版本控制中排除 (本地缓存, 由 specforge install 重建);
    # 但保留 .specforge/project/ 入库 — 那是项目的 spec / project-info 等产出物.
    local GITIGNORE="$PROJECT_NAME/.gitignore"
    if [ ! -f "$GITIGNORE" ]; then
        printf '.specforge/agents/\n.specforge/templates/\n' > "$GITIGNORE"
    else
        grep -qxF '.specforge/agents/' "$GITIGNORE" 2>/dev/null \
            || printf '\n.specforge/agents/\n' >> "$GITIGNORE"
        grep -qxF '.specforge/templates/' "$GITIGNORE" 2>/dev/null \
            || printf '.specforge/templates/\n' >> "$GITIGNORE"
    fi

    local AGENT_COUNT TEMPLATE_COUNT
    AGENT_COUNT=$(ls "$PROJECT_NAME/.specforge/agents"/*.md 2>/dev/null | wc -l | tr -d ' ')
    TEMPLATE_COUNT=$(ls "$PROJECT_NAME/.specforge/templates"/*.md 2>/dev/null | wc -l | tr -d ' ')

    cat <<EOF

specforge project '$PROJECT_NAME' initialized!

  项目目录:   $(pwd)/$PROJECT_NAME
  Agent 目录:  $PROJECT_NAME/.specforge/agents/   ($AGENT_COUNT 个 Agent prompt)
  模板目录:    $PROJECT_NAME/.specforge/templates/ ($TEMPLATE_COUNT 个模板)
  Wiki 目录:   $PROJECT_NAME/wiki/

模型建议:
  - A 档 (Sage/Lex/Maestro):  主推理模型 — kimi-k2 / sonnet / gpt-5
  - B 档 (Scout/Probe 计划):  中等 — deepseek-v3 / qwen-max
  - C 档 (Probe 实施):        廉价 — deepseek-v4-flash / haiku

下一步:
  1. cd $PROJECT_NAME
  2. (建议) 运行体检:
     specforge checkup OWNER/REPO
  3. 加载 Guide Agent 了解如何使用:
     加载 .specforge/agents/Guide.md 到你的 AI 工具,问"我该如何开始?"
  4. 有了功能想法后,加载 Scout Agent 启动 §2.1 项目奠基

详细文档: .specforge/agents/README.md 第 8 节
EOF
}

# cmd_init_adopt: full FR-009..FR-015 implementation
# Flags:
#   --backup         back up existing files as .bak before skip (FR-011)
#   --force          overwrite existing files (FR-011)
#   --dry-run        print what would happen, change nothing (FR-012)
#   --with-issue-template  install .github/ISSUE_TEMPLATE/feature.yml
#   --no-gitignore   skip .gitignore append (FR-014)
#   --json           emit machine-readable JSON (FR-013)
cmd_init_adopt() {
    local BACKUP=0 FORCE=0 DRY_RUN=0 ISSUE_TEMPLATE=0 NO_GITIGNORE=0 JSON=0
    local TARGET=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --backup)               BACKUP=1 ;;
            --force)                FORCE=1 ;;
            --dry-run)              DRY_RUN=1 ;;
            --with-issue-template)  ISSUE_TEMPLATE=1 ;;
            --no-gitignore)         NO_GITIGNORE=1 ;;
            --json)                 JSON=1 ;;
            -*)                     die "unknown flag: $1" ;;
            *)                      TARGET="$1" ;;
        esac
        shift
    done

    [ -n "$TARGET" ] || die "Usage: specforge init <existing-path> [--dry-run] [--backup|--force] [--no-gitignore] [--with-issue-template] [--json]"

    # FR-015: target must be a git repo
    [ -d "$TARGET/.git" ] || die "adopt target '$TARGET' is not a git repo; run 'git init' first"

    # Convert TARGET to absolute path for cd
    local ABS_TARGET
    ABS_TARGET="$(cd "$TARGET" && pwd)" || die "cannot resolve '$TARGET'"
    cd "$ABS_TARGET" || die "cannot cd to '$TARGET'"

    [ -d "$SPECFORGE_HOME/agents" ] || die "agents/ not found in $SPECFORGE_HOME — is specforge installed?"
    [ -d "$SPECFORGE_HOME/templates" ] || die "templates/ not found in $SPECFORGE_HOME"

    # FR-010: create-if-missing for specforge-owned dirs.
    # 注意: .specforge/project/ 是项目产出物根目录; init 不会触碰其下任何文件,
    # 只在该目录缺失时 mkdir 一个空壳, 让 Scout/Sage 等后续 agent 写入时不至于路径不存在.
    for d in .specforge/agents .specforge/templates .specforge/project wiki/pages wiki/decisions raw/sources; do
        if [ ! -d "$d" ]; then
            [ "$DRY_RUN" -eq 0 ] && mkdir -p "$d"
        fi
    done

    # FR-011: copy agents/*.md and templates/*.md with skip/backup/force
    # 目标路径改为 .specforge/ 下, 不污染项目根目录.
    local added_list="" skipped_list="" backed_list=""
    for src_dir in agents templates; do
        for f in "$SPECFORGE_HOME/$src_dir"/*.md; do
            [ -f "$f" ] || continue
            local dest=".specforge/$src_dir/$(basename "$f")"
            if [ ! -e "$dest" ]; then
                [ "$DRY_RUN" -eq 0 ] && cp "$f" "$dest"
                added_list="${added_list}${dest}"$'\n'
            elif cmp -s "$f" "$dest"; then
                # identical — silent skip (FR-011 AC-1)
                skipped_list="${skipped_list}${dest}"$'\n'
            elif [ "$FORCE" -eq 1 ]; then
                [ "$DRY_RUN" -eq 0 ] && cp "$f" "$dest"
                note "$dest exists, force-overwritten"
                skipped_list="${skipped_list}${dest}"$'\n'
            elif [ "$BACKUP" -eq 1 ]; then
                [ "$DRY_RUN" -eq 0 ] && cp "$dest" "$dest.bak"
                # Original preserved; .bak created; file NOT overwritten
                backed_list="${backed_list}${dest}"$'\n'
            else
                note "$dest exists, skipped"
                skipped_list="${skipped_list}${dest}"$'\n'
            fi
        done
    done

    # FR-029: .github/agents/*.agent.md 软链 (VS Code custom agent 发现)
    # 只有检测到 .vscode/ 目录 (说明用户使用 VS Code) 才创建, 不强制性.
    if [ -d ".vscode" ]; then
        if [ "$DRY_RUN" -eq 0 ]; then
            mkdir -p ".github/agents"
            for f in ".specforge/agents"/*.md; do
                [ -f "$f" ] || continue
                local agent_base
                agent_base=$(basename "$f" .md)
                ln -snf "../../.specforge/agents/${agent_base}.md" \
                    ".github/agents/${agent_base}.agent.md"
            done
        fi
        # .gitignore 追加 .github/agents/
        if [ "$NO_GITIGNORE" -eq 0 ]; then
            if [ ! -f ".gitignore" ]; then
                [ "$DRY_RUN" -eq 0 ] && printf ".github/agents/\n" > ".gitignore"
            elif ! grep -qxF '.github/agents/' .gitignore 2>/dev/null; then
                [ "$DRY_RUN" -eq 0 ] && printf "\n.github/agents/\n" >> ".gitignore"
            fi
        fi
    fi

    # FR-014: ignore agents/ + templates/ 副本 (本地缓存, 由 specforge install 重建);
    # 但保留 .specforge/project/ 入库 — 那是项目的 spec / project-info 等产出物, 不能被 ignore.
    if [ "$NO_GITIGNORE" -eq 0 ]; then
        if [ ! -f ".gitignore" ]; then
            [ "$DRY_RUN" -eq 0 ] && printf ".specforge/agents/\n.specforge/templates/\n" > ".gitignore"
        else
            if ! grep -qxF '.specforge/agents/' .gitignore 2>/dev/null; then
                [ "$DRY_RUN" -eq 0 ] && printf "\n.specforge/agents/\n" >> ".gitignore"
            fi
            if ! grep -qxF '.specforge/templates/' .gitignore 2>/dev/null; then
                [ "$DRY_RUN" -eq 0 ] && printf ".specforge/templates/\n" >> ".gitignore"
            fi
        fi
    fi

    # Optional: install feature.yml (off by default)
    if [ "$ISSUE_TEMPLATE" -eq 1 ]; then
        mkdir -p ".github/ISSUE_TEMPLATE"
        [ -f "$SPECFORGE_HOME/.github/ISSUE_TEMPLATE/feature.yml" ] \
            && cp "$SPECFORGE_HOME/.github/ISSUE_TEMPLATE/feature.yml" ".github/ISSUE_TEMPLATE/feature.yml"
    fi

    # FR-013: report
    local added_n skipped_n backed_n
    added_n=$(echo -n "$added_list" | grep -c . || true)
    skipped_n=$(echo -n "$skipped_list" | grep -c . || true)
    backed_n=$(echo -n "$backed_list" | grep -c . || true)

    if [ "$JSON" -eq 1 ]; then
        local added_j="" skipped_j="" backed_j=""
        [ -n "$added_list" ]   && added_j=$(echo "$added_list" | grep . | sed 's/.*/"&"/' | paste -sd, -)
        [ -n "$skipped_list" ] && skipped_j=$(echo "$skipped_list" | grep . | sed 's/.*/"&"/' | paste -sd, -)
        [ -n "$backed_list" ]  && backed_j=$(echo "$backed_list" | grep . | sed 's/.*/"&"/' | paste -sd, -)
        echo "{ \"added\": [${added_j:-}], \"skipped\": [${skipped_j:-}], \"backed_up\": [${backed_j:-}] }"
    else
        [ -n "$added_list" ]   && echo "$added_list"   | grep . | sed 's/^/[+] /'
        [ -n "$skipped_list" ] && echo "$skipped_list" | grep . | sed 's/^/[=] /'
        [ -n "$backed_list" ]  && echo "$backed_list"  | grep . | sed 's/^/[!] /'
        echo
        echo "$added_n 个新文件, $skipped_n 个跳过, $backed_n 个备份"
    fi
}

cmd_checkup() {
    local REPO="${1:-}"
    [ -z "$REPO" ] && die "Usage: specforge checkup <owner/repo>"
    local PY
    PY="$(resolve_python)"
    # 把 --offline / --gh-user 等后续参数完整透传,供 bats 离线模式使用
    shift
    exec "$PY" "$SPECFORGE_HOME/tools/check_identity.py" --repo "$REPO" "$@"
}

cmd_foundation() {
    local REPO="${1:-}"
    [ -z "$REPO" ] && die "Usage: specforge foundation <owner/repo> --version <version> [--spec-id <id>]"
    local PY
    PY="$(resolve_python)"
    shift
    exec "$PY" "$SPECFORGE_HOME/tools/check_foundation.py" "$REPO" "$@"
}

cmd_verify_issue() {
    local PY
    PY="$(resolve_python)"
    # 所有参数透传给 Python 脚本
    exec "$PY" "$SPECFORGE_HOME/tools/verify_issue_schema.py" "$@"
}

# quote-check: 包装 tools/quote_parser.py,避免 agent 直接 python3 调用
# (避免环境/版本/路径差异)
# 自动解析 spec path:即使 cwd 不是 git root,也能找到 .specforge/project/specs/... 下的文件
cmd_quote_check() {
    local PY
    PY="$(resolve_python)"
    local RESOLVED_ARGS=()
    local SPEC_PATH=""
    # 把第一个非 flag 参数当作 spec path 解析(quote_parser 用法: file 或 --check-ready file)
    for arg in "$@"; do
        if [[ "$arg" == -* ]]; then
            RESOLVED_ARGS+=("$arg")
        elif [ -z "$SPEC_PATH" ]; then
            SPEC_PATH="$(resolve_spec_path "$arg")"
            RESOLVED_ARGS+=("$SPEC_PATH")
        else
            RESOLVED_ARGS+=("$arg")
        fi
    done
    exec "$PY" "$SPECFORGE_HOME/tools/quote_parser.py" "${RESOLVED_ARGS[@]}"
}

# verify-acceptance: 验证 Sage 生成的 acceptance.md (Lex 阶段一调用)
cmd_verify_acceptance() {
    local PY
    PY="$(resolve_python)"
    local RESOLVED_ARGS=()
    # 把位置参数拷到数组, 然后用 while 遍历
    local ARGS=("$@")
    local n=${#ARGS[@]}
    local i=0
    while [ "$i" -lt "$n" ]; do
        local arg="${ARGS[$i]}"
        if [ "$arg" = "--spec-file" ] && [ $((i+1)) -lt "$n" ]; then
            RESOLVED_ARGS+=("--spec-file" "$(resolve_spec_path "${ARGS[$((i+1))]}")")
            i=$((i+2))
            continue
        fi
        if [ "$arg" = "--acceptance-file" ] && [ $((i+1)) -lt "$n" ]; then
            RESOLVED_ARGS+=("--acceptance-file" "$(resolve_spec_path "${ARGS[$((i+1))]}")")
            i=$((i+2))
            continue
        fi
        RESOLVED_ARGS+=("$arg")
        i=$((i+1))
    done
    exec "$PY" "$SPECFORGE_HOME/tools/verify_acceptance.py" "${RESOLVED_ARGS[@]}"
}

cmd_doctor() {
    cmd_checkup "$@"
}

# invite-owner: 把 repo owner 设为 {repo}-{version} project 的 READER
# 使用场景: agent (gh) 不是 repo owner,创建的 project 在 agent 名下。
#           需要把 repo owner 加为 project READER,让 owner 能看到 project。
cmd_invite_owner() {
    local REPO="${1:-}"
    [ -z "$REPO" ] && die "Usage: specforge invite-owner <owner/repo> --version <version>"
    local VERSION=""
    shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --version) VERSION="$2"; shift 2 ;;
            *) die "Unknown flag: $1" ;;
        esac
    done
    [ -z "$VERSION" ] && die "specforge invite-owner: --version is required"

    local REPO_BASENAME="${REPO##*/}"
    local EXPECTED_TITLE="${REPO_BASENAME}-${VERSION}"

    note "invite-owner: 查找 project '${EXPECTED_TITLE}' ..."

    # 1. 拿 gh 身份 (project 在他名下)
    local GH_USER
    GH_USER="$(gh api user -q .login 2>/dev/null)" || die "gh 未认证"
    note "  gh 身份: $GH_USER"

    # 2. 找 project id (在 gh 名下找)
    local PROJECT_ID
    PROJECT_ID="$(gh project list --owner "$GH_USER" --format json 2>/dev/null \
        | python3 -c "
import json, sys
data = json.load(sys.stdin)
for p in data.get('projects', []):
    if p.get('title', '').lower() == '${EXPECTED_TITLE}'.lower():
        print(p['id'])
        break
")"
    if [ -z "$PROJECT_ID" ]; then
        die "在 $GH_USER 名下未找到 project '${EXPECTED_TITLE}'。请先 'gh project create --owner $GH_USER --title ${EXPECTED_TITLE}'"
    fi
    note "  project id: $PROJECT_ID"

    # 3. 拿 repo owner userId
    local OWNER="${REPO%/*}"
    local OWNER_ID
    OWNER_ID="$(gh api graphql -f query="{ user(login: \"${OWNER}\") { id } }" -q .data.user.id 2>/dev/null)" \
        || die "无法获取 ${OWNER} 的 user id (GraphQL)"
    note "  owner ${OWNER} userId: $OWNER_ID"

    # 4. 调 updateProjectV2Collaborators
    local RESULT
    RESULT="$(gh api graphql -f query="
mutation {
  updateProjectV2Collaborators(input: {
    projectId: \"${PROJECT_ID}\",
    collaborators: [{ userId: \"${OWNER_ID}\", role: READER }]
  }) {
    clientMutationId
  }
}")" || die "invite-owner: GraphQL mutation 失败: $RESULT"

    echo "specforge: ${OWNER} 已加入 project '${EXPECTED_TITLE}' 为 READER"
}

cmd_upgrade() {
    [ -d "$SPECFORGE_HOME/.git" ] || die "$SPECFORGE_HOME is not a git clone; cannot upgrade"
    # 拒绝在非 main 分支上升级 — 那是开发者的 dev 仓,不是 install 仓
    local CURRENT
    CURRENT="$(cd "$SPECFORGE_HOME" && git rev-parse --abbrev-ref HEAD)"
    [ "$CURRENT" = "main" ] || die "refusing to upgrade on branch '$CURRENT' (only main is supported)"

    note "fetching origin/main into $SPECFORGE_HOME ..."
    (
        cd "$SPECFORGE_HOME"
        git fetch origin main
        git merge --ff-only origin/main
    )
    local NEW_VERSION
    NEW_VERSION="$(cat "$SPECFORGE_HOME/VERSION" 2>/dev/null || echo "?")"
    note "upgraded to $NEW_VERSION"
}

# ---------- dispatch ----------

case "${1:-help}" in
    init)        shift; cmd_init "$@" ;;
    checkup)     shift; cmd_checkup "$@" ;;
    foundation)  shift; cmd_foundation "$@" ;;
    invite-owner) shift; cmd_invite_owner "$@" ;;
    verify-issue) shift; cmd_verify_issue "$@" ;;
    quote-check) shift; cmd_quote_check "$@" ;;
    verify-acceptance) shift; cmd_verify_acceptance "$@" ;;
    doctor)      shift; cmd_doctor "$@" ;;
    upgrade)     shift; cmd_upgrade "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"") cmd_help ;;
    *) die "unknown command: $1 (try 'specforge help')" ;;
esac
