{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:machine-contract:build-artifact:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["kind", "identity", "revision", "schema_ref", "manifest_ref", "scope", "generated_by", "compatible_runtime", "artifact_refs", "payload"],
  "properties": {
    "kind": {"const": "build-artifact"}, "identity": {"const": "louke.contract.v0.14-002.build-artifact"}, "revision": {"const": "prism-round-3-remediation-candidate"}, "schema_ref": {"$ref": "#/$defs/schemaRef"}, "manifest_ref": {"$ref": "#/$defs/manifestRef"}, "scope": {"$ref": "#/$defs/scope"}, "generated_by": {"$ref": "#/$defs/generator"}, "compatible_runtime": {"const": ">=0.14.0,<0.15.0"}, "artifact_refs": {"$ref": "#/$defs/refs"},
    "payload": {"type": "object", "additionalProperties": false, "required": ["commands", "prepare_version", "build_command", "artifacts", "comparison", "ordered_gate", "evidence", "failure_policy"], "properties": {
      "commands": {"$ref": "#/$defs/commands"}, "prepare_version": {"const": "python tools/louke_python_release_adapter.py prepare --tag v0.14.0"}, "build_command": {"const": "python -m build"},
      "artifacts": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["id", "glob", "required", "extract_command", "digest_algorithm", "installed_outlets"], "properties": {"id": {"enum": ["wheel", "sdist"]}, "glob": {"type": "string", "minLength": 1}, "required": {"const": true}, "extract_command": {"const": "python tools/louke_python_release_adapter.py inspect --artifact PATH"}, "digest_algorithm": {"const": "sha256"}, "installed_outlets": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"enum": ["lk --version", "python -c importlib.metadata.version('louke')", "installed Archer/Prism prompt bundle readback", "installed registry/schema readback"]}}}}},
      "comparison": {"type": "string", "minLength": 1}, "ordered_gate": {"type": "array", "minItems": 5, "items": {"type": "string", "minLength": 1}},
      "evidence": {"type": "array", "const": ["version-scheme-selected", "version-source-prepared", "artifacts-built", "artifact-versions-verified"]}, "failure_policy": {"$ref": "#/$defs/failure"}
    }}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"const": "louke.machine-contract.build-artifact"}, "version": {"const": "1.0.0"}, "digest": {"$ref": "#/$defs/digest"}}},
    "manifestRef": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"const": "louke.design-artifacts.v0.14-002.prism-r3-remediation"}, "revision": {"const": "prism-round-3-remediation-candidate"}}},
    "artifactIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "identity", "revision"], "properties": {"kind": {"type": "string"}, "path": {"type": "string"}, "identity": {"type": "string"}, "revision": {"type": "string"}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["workspace_id", "spec_id", "base_commit", "project_facts_digest", "project_facts_artifact", "release_identity"], "properties": {"workspace_id": {"type": "string"}, "spec_id": {"const": "v0.14-002-workflow-reflow-design"}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "project_facts_digest": {"$ref": "#/$defs/digest"}, "project_facts_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "host-project-facts-snapshot"}}}, "release_identity": {"const": "0.14.0"}}},
    "generator": {"type": "object", "additionalProperties": false, "required": ["owner", "role", "task_manifest_digest", "task_manifest_artifact"], "properties": {"owner": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "task_manifest_digest": {"$ref": "#/$defs/digest"}, "task_manifest_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "archer-author-task-manifest"}}}}},
    "refs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "ac_ids", "interface_ids", "architecture_anchors", "contract_kind"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "ac_ids": {"type": "array", "items": {"type": "string"}}, "interface_ids": {"type": "array", "items": {"type": "string"}}, "architecture_anchors": {"type": "array", "items": {"type": "string"}}, "contract_kind": {"const": "build-artifact"}}}},
    "commands": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["id", "cwd", "command", "implementation_state", "success", "failure"], "properties": {"id": {"enum": ["build", "inspect"]}, "cwd": {"type": "string"}, "command": {"type": "string", "minLength": 1}, "implementation_state": {"enum": ["existing", "candidate-change-required"]}, "success": {"type": "string"}, "failure": {"type": "string"}}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["fail_closed", "non_success", "current_state"], "properties": {"fail_closed": {"const": true}, "non_success": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["identity-invalid", "source-failure", "build-failure", "artifact-missing", "extract-failure", "version-mismatch", "prompt-or-schema-mismatch", "outlet-mismatch", "unknown"]}}, "current_state": {"const": "candidate-not-installed"}}}
  }
}
