{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:machine-contract:github-actions-ci:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["kind", "identity", "revision", "schema_ref", "manifest_ref", "scope", "generated_by", "compatible_runtime", "artifact_refs", "payload"],
  "properties": {
    "kind": {"const": "github-actions-ci"}, "identity": {"const": "louke.contract.v0.14-002.github-actions-ci"}, "revision": {"const": "prism-round-3-remediation-candidate"}, "schema_ref": {"$ref": "#/$defs/schemaRef"}, "manifest_ref": {"$ref": "#/$defs/manifestRef"}, "scope": {"$ref": "#/$defs/scope"}, "generated_by": {"$ref": "#/$defs/generator"}, "compatible_runtime": {"const": ">=0.14.0,<0.15.0"}, "artifact_refs": {"$ref": "#/$defs/refs"},
    "payload": {"type": "object", "additionalProperties": false, "required": ["commands", "provider", "managed_path", "owner_marker", "contract_revision", "target_branches", "triggers", "runner_matrix", "setup", "jobs", "dag", "permissions", "secrets", "services", "caches", "evidence", "timeouts", "required_check", "rules_readback", "failure_policy"], "properties": {
      "commands": {"$ref": "#/$defs/commands"}, "provider": {"const": "github-actions"}, "managed_path": {"const": ".github/workflows/louke-ci.yml"}, "owner_marker": {"type": "string", "minLength": 1}, "contract_revision": {"const": "prism-round-3-remediation-candidate"},
      "target_branches": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "triggers": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"enum": ["pull_request", "push", "workflow_dispatch", "release prerequisite"]}},
      "runner_matrix": {"type": "object", "additionalProperties": false, "required": ["default", "unit_python"], "properties": {"default": {"const": "ubuntu-22.04"}, "unit_python": {"type": "array", "const": ["3.11", "3.12", "3.13", "3.14"]}}},
      "setup": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
      "jobs": {"type": "array", "minItems": 9, "items": {"$ref": "#/$defs/job"}},
      "dag": {"type": "object", "additionalProperties": false, "required": ["edges", "aggregate"], "properties": {"edges": {"type": "array", "minItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["from", "to"], "properties": {"from": {"type": "string", "minLength": 1}, "to": {"type": "string", "minLength": 1}}}}, "aggregate": {"const": "all mandatory jobs -> Louke CI / required with if: always()"}}},
      "permissions": {"type": "object", "additionalProperties": false, "required": ["default", "pull_request_write", "fork_pr_secrets"], "properties": {"default": {"const": "contents: read"}, "pull_request_write": {"const": false}, "fork_pr_secrets": {"const": false}}},
      "secrets": {"type": "object", "additionalProperties": false, "required": ["fork_pr", "production"], "properties": {"fork_pr": {"type": "array", "maxItems": 0}, "production": {"const": "protected release/manual environment only"}}},
      "services": {"type": "array", "items": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["id", "managed_by"], "properties": {"id": {"const": "workbench"}, "managed_by": {"const": "e2e runner"}}}, {"type": "object", "additionalProperties": false, "required": ["id", "mode"], "properties": {"id": {"const": "providers"}, "mode": {"const": "stand-in in default CI"}}}]}},
      "caches": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "key_inputs"], "properties": {"id": {"enum": ["pip", "playwright"]}, "key_inputs": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}}},
      "evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "timeouts": {"type": "object", "additionalProperties": false, "required": ["quality", "design-contract", "ac-trace", "build-artifacts", "artifact-verify", "unit", "integration", "e2e-standin", "required"], "properties": {"quality": {"const": 10}, "design-contract": {"const": 10}, "ac-trace": {"const": 10}, "build-artifacts": {"const": 15}, "artifact-verify": {"const": 15}, "unit": {"const": 20}, "integration": {"const": 30}, "e2e-standin": {"const": 40}, "required": {"const": 5}}},
      "required_check": {"const": "Louke CI / required"},
      "rules_readback": {"type": "object", "additionalProperties": false, "required": ["owner", "target", "fallback", "preserve_existing"], "properties": {"owner": {"const": "Louke Runtime"}, "target": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "fallback": {"const": "branch protection when ruleset unsupported"}, "preserve_existing": {"const": true}}},
      "failure_policy": {"$ref": "#/$defs/failure"}
    }}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"const": "louke.machine-contract.github-actions-ci"}, "version": {"const": "1.0.0"}, "digest": {"$ref": "#/$defs/digest"}}},
    "manifestRef": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"const": "louke.design-artifacts.v0.14-002.prism-r3-remediation"}, "revision": {"const": "prism-round-3-remediation-candidate"}}},
    "artifactIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "identity", "revision"], "properties": {"kind": {"type": "string"}, "path": {"type": "string"}, "identity": {"type": "string"}, "revision": {"type": "string"}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["workspace_id", "spec_id", "base_commit", "project_facts_digest", "project_facts_artifact", "release_identity"], "properties": {"workspace_id": {"type": "string"}, "spec_id": {"const": "v0.14-002-workflow-reflow-design"}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "project_facts_digest": {"$ref": "#/$defs/digest"}, "project_facts_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "host-project-facts-snapshot"}}}, "release_identity": {"const": "0.14.0"}}},
    "generator": {"type": "object", "additionalProperties": false, "required": ["owner", "role", "task_manifest_digest", "task_manifest_artifact"], "properties": {"owner": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "task_manifest_digest": {"$ref": "#/$defs/digest"}, "task_manifest_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "archer-author-task-manifest"}}}}},
    "refs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "ac_ids", "interface_ids", "architecture_anchors", "contract_kind"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "ac_ids": {"type": "array", "items": {"type": "string"}}, "interface_ids": {"type": "array", "items": {"type": "string"}}, "architecture_anchors": {"type": "array", "items": {"type": "string"}}, "contract_kind": {"const": "github-actions-ci"}}}},
    "commands": {"type": "array", "minItems": 9, "items": {"type": "object", "additionalProperties": false, "required": ["id", "cwd", "command", "implementation_state", "success", "failure"], "properties": {"id": {"type": "string", "minLength": 1}, "cwd": {"type": "string", "minLength": 1}, "command": {"type": "string", "minLength": 1}, "implementation_state": {"enum": ["existing", "candidate-change-required"]}, "success": {"type": "string", "minLength": 1}, "failure": {"type": "string", "minLength": 1}}}},
    "job": {"type": "object", "additionalProperties": false, "required": ["id", "required", "command_ref", "needs", "timeout_minutes", "permissions", "evidence"], "properties": {"id": {"enum": ["quality", "design-contract", "ac-trace", "build-artifacts", "artifact-verify", "unit", "integration", "e2e-standin", "Louke CI / required"]}, "required": {"const": true}, "command_ref": {"type": "string", "minLength": 1}, "needs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "timeout_minutes": {"type": "integer", "minimum": 1, "maximum": 40}, "permissions": {"const": "contents: read"}, "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["fail_closed", "non_success", "current_state"], "properties": {"fail_closed": {"const": true}, "non_success": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["failure", "cancel", "timeout", "missing", "skip", "not-run", "unknown", "drift", "secret"]}}, "current_state": {"const": "candidate-not-installed"}}}
  }
}
