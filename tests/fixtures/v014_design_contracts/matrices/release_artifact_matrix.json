  "cases": [
    {
      "id": "canonical-wheel-sdist",
      "description": "Both wheel and sdist built, digests match, installed version matches source",
      "artifacts": ["wheel", "sdist"],
      "expected": "PASS"
    },
    {
      "id": "missing-sdist",
      "description": "Only wheel built; sdist missing",
      "artifacts": ["wheel"],
      "expected": "FAIL: missing sdist"
    },
    {
      "id": "missing-wheel",
      "description": "Only sdist built; wheel missing",
      "artifacts": ["sdist"],
      "expected": "FAIL: missing wheel"
    },
    {
