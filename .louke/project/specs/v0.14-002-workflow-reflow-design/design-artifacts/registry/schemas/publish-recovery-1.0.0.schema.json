{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:machine-contract:publish-recovery:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["kind", "identity", "revision", "schema_ref", "manifest_ref", "scope", "generated_by", "compatible_runtime", "artifact_refs", "payload"],
  "properties": {
    "kind": {"const": "publish-recovery"}, "identity": {"const": "louke.contract.v0.14-002.publish-recovery"}, "revision": {"const": "prism-round-3-remediation-candidate"}, "schema_ref": {"$ref": "#/$defs/schemaRef"}, "manifest_ref": {"$ref": "#/$defs/manifestRef"}, "scope": {"$ref": "#/$defs/scope"}, "generated_by": {"$ref": "#/$defs/generator"}, "compatible_runtime": {"const": ">=0.14.0,<0.15.0"}, "artifact_refs": {"$ref": "#/$defs/refs"},
    "payload": {"type": "object", "additionalProperties": false, "required": ["commands", "release_identity", "operations", "preconditions", "statuses", "query_before_retry", "idempotency", "credentials", "partial_success", "post_publish_verification", "deployment", "failure_policy"], "properties": {
      "commands": {"$ref": "#/$defs/commands"}, "release_identity": {"const": "0.14.0"},
      "operations": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "object", "additionalProperties": false, "required": ["order", "kind", "expected_identity", "query", "verify", "recovery"], "properties": {"order": {"type": "integer", "minimum": 1, "maximum": 5}, "kind": {"enum": ["merge-main-evidence", "tag", "pypi", "github-release", "clean-install-smoke"]}, "expected_identity": {"type": "string", "minLength": 1}, "query": {"type": "string", "minLength": 1}, "verify": {"type": "string", "minLength": 1}, "recovery": {"type": "string", "minLength": 1}}}},
      "preconditions": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "statuses": {"type": "array", "const": ["planned", "executing", "confirmed", "failed", "uncertain", "needs_attention", "rolled_back", "forward_fix_required"]},
      "query_before_retry": {"const": true}, "idempotency": {"type": "string", "minLength": 1},
      "credentials": {"type": "object", "additionalProperties": false, "required": ["storage", "PR_access", "minimum_scope_per_operation"], "properties": {"storage": {"const": "secret references only"}, "PR_access": {"const": false}, "minimum_scope_per_operation": {"const": true}}},
      "partial_success": {"type": "string", "minLength": 1}, "post_publish_verification": {"type": "string", "minLength": 1},
      "deployment": {"type": "object", "additionalProperties": false, "required": ["applicable", "reason"], "properties": {"applicable": {"const": false}, "reason": {"const": "Louke is a local Python package; no independent deployment endpoint"}}},
      "failure_policy": {"$ref": "#/$defs/failure"}
    }}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"const": "louke.machine-contract.publish-recovery"}, "version": {"const": "1.0.0"}, "digest": {"$ref": "#/$defs/digest"}}},
    "manifestRef": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"const": "louke.design-artifacts.v0.14-002.prism-r3-remediation"}, "revision": {"const": "prism-round-3-remediation-candidate"}}},
    "artifactIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "identity", "revision"], "properties": {"kind": {"type": "string"}, "path": {"type": "string"}, "identity": {"type": "string"}, "revision": {"type": "string"}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["workspace_id", "spec_id", "base_commit", "project_facts_digest", "project_facts_artifact", "release_identity"], "properties": {"workspace_id": {"type": "string"}, "spec_id": {"const": "v0.14-002-workflow-reflow-design"}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "project_facts_digest": {"$ref": "#/$defs/digest"}, "project_facts_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "host-project-facts-snapshot"}}}, "release_identity": {"const": "0.14.0"}}},
    "generator": {"type": "object", "additionalProperties": false, "required": ["owner", "role", "task_manifest_digest", "task_manifest_artifact"], "properties": {"owner": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "task_manifest_digest": {"$ref": "#/$defs/digest"}, "task_manifest_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "archer-author-task-manifest"}}}}},
    "refs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "ac_ids", "interface_ids", "architecture_anchors", "contract_kind"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "ac_ids": {"type": "array", "items": {"type": "string"}}, "interface_ids": {"type": "array", "items": {"type": "string"}}, "architecture_anchors": {"type": "array", "items": {"type": "string"}}, "contract_kind": {"const": "publish-recovery"}}}},
    "commands": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "cwd", "command", "implementation_state", "success", "failure"], "properties": {"id": {"const": "publish-reconcile"}, "cwd": {"type": "string"}, "command": {"type": "string", "minLength": 1}, "implementation_state": {"const": "candidate-change-required"}, "success": {"type": "string"}, "failure": {"type": "string"}}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["fail_closed", "non_success", "current_state"], "properties": {"fail_closed": {"const": true}, "non_success": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["failed", "uncertain", "needs_attention", "partial-unreconciled", "credential-missing", "gate-stale", "fact-zero", "fact-multiple", "conflict", "unknown"]}}, "current_state": {"const": "candidate-not-installed"}}}
  }
}
