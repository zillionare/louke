{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:machine-contract:pre-commit:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["kind", "identity", "revision", "schema_ref", "manifest_ref", "scope", "generated_by", "compatible_runtime", "artifact_refs", "payload"],
  "properties": {
    "kind": {"const": "pre-commit"}, "identity": {"const": "louke.contract.v0.14-002.pre-commit"}, "revision": {"const": "prism-round-3-remediation-candidate"}, "schema_ref": {"$ref": "#/$defs/schemaRef"}, "manifest_ref": {"$ref": "#/$defs/manifestRef"}, "scope": {"$ref": "#/$defs/scope"}, "generated_by": {"$ref": "#/$defs/generator"}, "compatible_runtime": {"const": ">=0.14.0,<0.15.0"}, "artifact_refs": {"$ref": "#/$defs/refs"},
    "payload": {"type": "object", "additionalProperties": false, "required": ["commands", "managed_config_path", "tool_version", "install_command", "stages", "hooks", "existing_hook_snapshot", "merge_policy", "authoritative_full_gate", "readback", "failure_policy"], "properties": {
      "commands": {"$ref": "#/$defs/commands"}, "managed_config_path": {"const": ".pre-commit-config.yaml"}, "tool_version": {"const": "4.6.0"}, "install_command": {"const": "pre-commit install"},
      "stages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["pre-commit", "commit-msg", "pre-push"]}},
      "hooks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "entry", "version", "timeout_seconds", "may_modify"], "properties": {"id": {"type": "string", "minLength": 1}, "entry": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 120}, "may_modify": {"type": "boolean"}}}},
      "existing_hook_snapshot": {"type": "object", "additionalProperties": false, "required": ["path", "policy"], "properties": {"path": {"const": ".pre-commit-config.yaml"}, "policy": {"type": "string", "minLength": 1}}},
      "merge_policy": {"type": "string", "minLength": 1}, "authoritative_full_gate": {"const": false},
      "readback": {"type": "object", "additionalProperties": false, "required": ["statuses", "installer_authority"], "properties": {"statuses": {"type": "array", "const": ["in_sync", "drifted", "missing", "conflict"]}, "installer_authority": {"const": "Runtime only"}}},
      "failure_policy": {"$ref": "#/$defs/failure"}
    }}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"const": "louke.machine-contract.pre-commit"}, "version": {"const": "1.0.0"}, "digest": {"$ref": "#/$defs/digest"}}},
    "manifestRef": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"const": "louke.design-artifacts.v0.14-002.prism-r3-remediation"}, "revision": {"const": "prism-round-3-remediation-candidate"}}},
    "artifactIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "identity", "revision"], "properties": {"kind": {"type": "string"}, "path": {"type": "string"}, "identity": {"type": "string"}, "revision": {"type": "string"}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["workspace_id", "spec_id", "base_commit", "project_facts_digest", "project_facts_artifact", "release_identity"], "properties": {"workspace_id": {"type": "string"}, "spec_id": {"const": "v0.14-002-workflow-reflow-design"}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "project_facts_digest": {"$ref": "#/$defs/digest"}, "project_facts_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "host-project-facts-snapshot"}}}, "release_identity": {"const": "0.14.0"}}},
    "generator": {"type": "object", "additionalProperties": false, "required": ["owner", "role", "task_manifest_digest", "task_manifest_artifact"], "properties": {"owner": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "task_manifest_digest": {"$ref": "#/$defs/digest"}, "task_manifest_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "archer-author-task-manifest"}}}}},
    "refs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "ac_ids", "interface_ids", "architecture_anchors", "contract_kind"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "ac_ids": {"type": "array", "items": {"type": "string"}}, "interface_ids": {"type": "array", "items": {"type": "string"}}, "architecture_anchors": {"type": "array", "items": {"type": "string"}}, "contract_kind": {"const": "pre-commit"}}}},
    "commands": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "cwd", "command", "implementation_state", "success", "failure"], "properties": {"id": {"type": "string"}, "cwd": {"type": "string"}, "command": {"type": "string", "minLength": 1}, "implementation_state": {"enum": ["existing", "candidate-change-required"]}, "success": {"type": "string"}, "failure": {"type": "string"}}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["fail_closed", "non_success", "current_state"], "properties": {"fail_closed": {"const": true}, "non_success": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["nonzero", "timeout", "modified", "missing", "drifted", "conflict", "secret", "unknown"]}}, "current_state": {"const": "candidate-not-installed"}}}
  }
}
