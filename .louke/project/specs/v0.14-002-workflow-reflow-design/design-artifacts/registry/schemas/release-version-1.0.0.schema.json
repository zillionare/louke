{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:machine-contract:release-version:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["kind", "identity", "revision", "schema_ref", "manifest_ref", "scope", "generated_by", "compatible_runtime", "artifact_refs", "payload"],
  "properties": {
    "kind": {"const": "release-version"}, "identity": {"type": "string", "minLength": 1}, "revision": {"type": "string", "minLength": 1}, "schema_ref": {"$ref": "#/$defs/schemaRef"}, "manifest_ref": {"$ref": "#/$defs/manifestRef"}, "scope": {"$ref": "#/$defs/scope"}, "generated_by": {"$ref": "#/$defs/generator"}, "compatible_runtime": {"type": "string", "minLength": 1}, "artifact_refs": {"$ref": "#/$defs/refs"},
    "payload": {"type": "object", "additionalProperties": false, "required": ["commands", "canonical_input", "normalization", "branch_mapping", "tag_mapping", "version_source", "adapter", "read_command", "prepare_command", "write_policy", "compare", "evidence", "failure_policy"], "properties": {
      "commands": {"$ref": "#/$defs/commands"}, "canonical_input": {"type": "string", "minLength": 1}, "normalization": {"type": "string", "minLength": 1}, "branch_mapping": {"type": "string", "minLength": 1}, "tag_mapping": {"type": "string", "minLength": 1},
      "version_source": {"type": "object", "additionalProperties": false, "required": ["path", "selector"], "properties": {"path": {"type": "string", "minLength": 1}, "selector": {"type": "string", "minLength": 1}}},
      "adapter": {"type": "string", "minLength": 1}, "read_command": {"type": "string", "minLength": 1}, "prepare_command": {"type": "string", "minLength": 1}, "write_policy": {"type": "string", "minLength": 1}, "compare": {"type": "string", "minLength": 1},
      "evidence": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"enum": ["version-scheme-selected", "version-source-prepared"]}}, "failure_policy": {"$ref": "#/$defs/failure"}
    }}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"const": "louke.machine-contract.release-version"}, "version": {"const": "1.0.0"}, "digest": {"$ref": "#/$defs/digest"}}},
    "manifestRef": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"type": "string", "minLength": 1}, "revision": {"type": "string", "minLength": 1}}},
    "artifactIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "identity", "revision"], "properties": {"kind": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "identity": {"type": "string", "minLength": 1}, "revision": {"type": "string", "minLength": 1}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["workspace_id", "spec_id", "base_commit", "project_facts_digest", "project_facts_artifact", "release_identity"], "properties": {"workspace_id": {"type": "string", "minLength": 1}, "spec_id": {"type": "string", "minLength": 1}, "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "project_facts_digest": {"$ref": "#/$defs/digest"}, "project_facts_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "host-project-facts-snapshot"}}}, "release_identity": {"type": "string", "minLength": 1}}},
    "generator": {"type": "object", "additionalProperties": false, "required": ["owner", "role", "task_manifest_digest", "task_manifest_artifact"], "properties": {"owner": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "task_manifest_digest": {"$ref": "#/$defs/digest"}, "task_manifest_artifact": {"allOf": [{"$ref": "#/$defs/artifactIdentity"}], "properties": {"kind": {"const": "archer-author-task-manifest"}}}}},
    "refs": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "ac_ids", "interface_ids", "architecture_anchors", "contract_kind"], "properties": {"path": {"type": "string", "minLength": 1}, "digest": {"$ref": "#/$defs/digest"}, "ac_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "interface_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "architecture_anchors": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "contract_kind": {"const": "release-version"}}}},
    "commands": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["id", "cwd", "command", "implementation_state", "success", "failure"], "properties": {"id": {"type": "string", "minLength": 1}, "cwd": {"type": "string", "minLength": 1}, "command": {"type": "string", "minLength": 1}, "implementation_state": {"enum": ["existing", "candidate-change-required"]}, "success": {"type": "string", "minLength": 1}, "failure": {"type": "string", "minLength": 1}}}},
    "failure": {"type": "object", "additionalProperties": false, "required": ["fail_closed", "non_success", "current_state"], "properties": {"fail_closed": {"const": true}, "non_success": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["missing", "invalid", "mismatch", "write-error", "unknown", "drift"]}}, "current_state": {"type": "string", "minLength": 1}}}
  }
}
