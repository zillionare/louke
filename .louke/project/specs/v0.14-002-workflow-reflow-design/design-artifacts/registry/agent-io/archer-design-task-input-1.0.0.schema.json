{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:louke:schema:agent-io:archer-design-task-input:1.0.0",
  "title": "Program-owned Archer M-DESIGN task input",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_kind", "schema_version", "input_schema_ref", "task_identity", "dispatch", "stage", "spec", "design_revision", "inputs", "allowed_write_set", "forbidden_effects", "output_contract", "freshness", "binding_state"],
  "properties": {
    "artifact_kind": {"const": "archer-author-task-manifest"},
    "schema_version": {"const": "1.0.0"},
    "input_schema_ref": {"$ref": "#/$defs/inputSchemaRef"},
    "task_identity": {"type": "string", "minLength": 1},
    "dispatch": {"$ref": "#/$defs/dispatch"},
    "stage": {"const": "M-DESIGN"},
    "spec": {"$ref": "#/$defs/spec"},
    "design_revision": {"$ref": "#/$defs/revision"},
    "inputs": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/inputArtifact"}},
    "allowed_write_set": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^\\.louke/project/specs/v0\\.14-002-workflow-reflow-design/(test-plan\\.md|architecture\\.md|interfaces\\.md|design-artifacts/.+)$"}},
    "forbidden_effects": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"enum": ["business-code-write", "test-code-write", "active-opencode-write", "project-toml-write", "review-artifact-write", "commit", "push", "dispatch", "activation", "stage-progression", "runtime-state-write", "external-side-effect"]}},
    "output_contract": {"$ref": "#/$defs/outputContract"},
    "freshness": {"$ref": "#/$defs/freshness"},
    "binding_state": {"const": "candidate-dispatch-readback-not-runtime-activated"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["identity", "version", "digest"], "properties": {"identity": {"type": "string", "minLength": 1}, "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "digest": {"$ref": "#/$defs/digest"}}},
    "inputSchemaRef": {"allOf": [{"$ref": "#/$defs/schemaRef"}], "properties": {"identity": {"const": "louke.agent-io.archer-design-task-input"}, "version": {"const": "1.0.0"}}},
    "dispatch": {"type": "object", "additionalProperties": false, "required": ["authority", "role", "mode", "attempt_id", "execution_transport"], "properties": {"authority": {"const": "Runtime/program"}, "role": {"const": "Archer"}, "mode": {"const": "subagent"}, "attempt_id": {"type": "string", "minLength": 1}, "execution_transport": {"$ref": "#/$defs/executionTransport"}}},
    "spec": {"type": "object", "additionalProperties": false, "required": ["id", "revision", "story_digest", "spec_digest", "acceptance_digest"], "properties": {"id": {"const": "v0.14-002-workflow-reflow-design"}, "revision": {"type": "string", "minLength": 1}, "story_digest": {"$ref": "#/$defs/digest"}, "spec_digest": {"$ref": "#/$defs/digest"}, "acceptance_digest": {"$ref": "#/$defs/digest"}}},
    "revision": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"const": "louke.design-artifacts.v0.14-002.prism-r3-remediation"}, "revision": {"const": "prism-round-3-remediation-candidate"}}},
    "inputArtifact": {"type": "object", "additionalProperties": false, "required": ["kind", "path", "digest", "required"], "properties": {"kind": {"enum": ["story", "spec", "acceptance", "design-review", "host-project-facts-snapshot", "prior-design-artifact-manifest", "prompt-source", "runner-fact"]}, "path": {"type": "string", "minLength": 1}, "digest": {"$ref": "#/$defs/digest"}, "required": {"const": true}}},
    "executionTransport": {"type": "object", "additionalProperties": false, "required": ["provider_metadata", "session_metadata"], "properties": {"provider_metadata": {"type": "object", "minProperties": 1, "additionalProperties": true}, "session_metadata": {"type": "object", "minProperties": 1, "additionalProperties": true}}},
    "outputContract": {"type": "object", "additionalProperties": false, "required": ["schema_ref", "delivery", "artifact_manifest_path"], "properties": {"schema_ref": {"allOf": [{"$ref": "#/$defs/schemaRef"}], "properties": {"identity": {"const": "louke.agent-io.archer-design-result"}, "version": {"const": "1.0.0"}}}, "delivery": {"const": "return-to-Runtime/program-for-validation-and-persistence"}, "artifact_manifest_path": {"const": ".louke/project/specs/v0.14-002-workflow-reflow-design/design-artifacts/design-artifact-manifest.candidate.json"}}},
    "freshness": {"type": "object", "additionalProperties": false, "required": ["base_commit", "input_set_digest", "invalidated_by", "policy"], "properties": {"base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "input_set_digest": {"$ref": "#/$defs/digest"}, "invalidated_by": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["requirements-digest-change", "design-review-digest-change", "project-facts-digest-change", "base-commit-change", "allowed-write-set-change", "output-schema-change", "prompt-bundle-change", "discussion-set-change"]}}, "policy": {"const": "input_set_digest is SHA-256 of canonical sorted-key compact JSON over design_revision, ordered inputs, allowed_write_set, forbidden_effects, output_contract and base_commit; any listed identity or digest change rejects this task and requires a new Runtime dispatch"}}}
  }
}
