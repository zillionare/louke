{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "urn:louke:schema:agent-io:archer-design-result:1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["status", "bound_input_digest", "artifact_manifest_path", "artifact_manifest_digest", "artifacts", "gaps", "handoff"],
  "properties": {
    "status": {"enum": ["candidate_complete", "blocked"]}, "bound_input_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifact_manifest_path": {"type": "string"}, "artifact_manifest_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "activation_state"], "properties": {"path": {"type": "string"}, "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "activation_state": {"enum": ["candidate", "candidate-not-installed", "candidate-not-deployed"]}}}},
    "gaps": {"type": "array", "items": {"type": "object"}}, "handoff": {"type": "string"}
  }
}
